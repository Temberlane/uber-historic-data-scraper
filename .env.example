# Uber API credentials
# Get these from https://developer.uber.com/dashboard
UBER_SERVER_TOKEN=your_uber_server_token_here

# Set to "true" to generate synthetic data without a real token (demo mode)
MOCK_MODE=false

# Directory where rides.csv and config.json are stored
# Defaults to ../data relative to the backend/scraper directory
DATA_DIR=../data

# Backend port (default: 5000)
PORT=5000

# Set to "true" to enable Flask debug mode (do not use in production)
FLASK_DEBUG=false
